# Ignore build artifacts
build/
assets/css/root.css
# theme.json is generated by the build but MUST be tracked: WordPress reads it
# from the theme root, and untracked root-level files are excluded from the
# deploy artifact (unlike assets/css/root.css which ships inside a packaged dir).
# The build still overwrites it each release, so it stays in sync with tokens.

# Node modules (if ever added)
node_modules/

# Composer vendor directory
vendor/

# OS / editor files
.DS_Store
*.swp

# Additional build and development files
package-lock.json
.claude/
CLAUDE.md
.buildignore
build.sh

# WordPress documentation sync (contains application password)
docs/.docs-sync.json
